# Copy to your machine environment or Cursor MCP env (do not commit real values).
# Regenerate any secret that was ever pasted into chat or committed.

# Full URL from Unframer MCP settings, including id and secret query params
UNFRAMER_MCP_URL=https://mcp.unframer.co/mcp?id=YOUR_PROJECT_ID&secret=YOUR_SECRET

# GitHub Copilot MCP — value Copilot expects (often raw token or Bearer <token>)
GITHUB_COPILOT_MCP_AUTHORIZATION=

# Google Stitch MCP
STITCH_GOOGLE_API_KEY=
